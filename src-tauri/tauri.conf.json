{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Knowledge Base",
  "version": "0.2.0",
  "identifier": "com.agilefr.kb",
  "build": {
    "beforeDevCommand": "pnpm dev:clean",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "知识库",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost https://fonts.gstatic.com data: blob:; connect-src 'self' http://localhost:* https://*; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://pub-9d9e6c0cb6934fb0a0c505e3c64f39b2.r2.dev/knowledge-base/update.json",
        "https://github.com/bkywksj/knowledge-base-release/raw/main/update.json",
        "https://gitee.com/bkywksj/knowledge-base-release/raw/main/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCODc4OUM5MERBNEFBMUIKUldRYnFxUU55WW1IYXk3L2tTR3V3Z1JTRGhIRXJyWTc2MEpydU9EMkRMaytxVkZ2UFZFdEZrQmYK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown 文件",
        "description": "由知识库打开",
        "role": "Editor"
      }
    ],
    "copyright": "Copyright (c) 2026 AgileFR",
    "category": "Productivity",
    "shortDescription": "本地知识库桌面应用",
    "longDescription": "基于 Tauri 构建的本地知识库管理工具，支持 Markdown 编辑、全文搜索、双向链接、知识图谱、AI 问答等功能。",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["SimpChinese", "English"],
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"],
        "section": "utility"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
